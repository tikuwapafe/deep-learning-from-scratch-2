# コサイン類似度
# 0除算の発生を防ぐため、小さな値を加算する
def cos_similarity(x, y, eps=1e-8):
    nx = x/(np.sqrt(np.sum(x**2))+eps)
    ny = y/(np.sqrt(np.sum(y**2))+eps)
    return np.dot(nx, ny)


x = np.array([100, -20, 2])
x.argsort() #小さい順にソート


# 大きい順にソート
(-x).argsort()


